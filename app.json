{
  "expo": {
    "name": "Minds",
    "slug": "minds",
    "version": "2.0.0",
    "scheme": "minds",
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "ios": {
      "bundleIdentifier": "com.minds.app",
      "associatedDomains": ["applinks:minds.on.recursiv.io", "applinks:minds.com"]
    },
    "android": {
      "package": "com.minds.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "minds.on.recursiv.io" },
            { "scheme": "https", "host": "minds.com" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
