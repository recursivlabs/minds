{
  "expo": {
    "name": "Minds",
    "slug": "minds",
    "version": "2.0.0",
    "scheme": "minds",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "ios": {
      "bundleIdentifier": "com.minds.app",
      "associatedDomains": [
        "applinks:minds.on.recursiv.io",
        "applinks:minds.com"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.minds.app",
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#08080a"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "minds.on.recursiv.io"
            },
            {
              "scheme": "https",
              "host": "minds.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-notifications",
        {
          "color": "#1b6ef3"
        }
      ],
      "expo-font",
      "expo-video",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "backgroundColor": "#08080a"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Minds uses your photo library so you can attach photos and videos to posts and set your avatar.",
          "cameraPermission": "Minds uses your camera so you can take photos and videos for posts."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}