{
  "name": "minds-app",
  "version": "2.0.0",
  "main": "index.js",
  "scripts": {
    "start": "serve dist -l 3000 -s",
    "build": "EXPO_UNSTABLE_TREE_SHAKING=0 EXPO_UNSTABLE_METRO_OPTIMIZE_GRAPH=0 expo export --platform web && node scripts/inject-boot-shell.mjs",
    "dev": "expo start",
    "web": "expo start --web",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint app components lib"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@recursiv/sdk": "0.5.6",
    "dompurify": "^3.4.11",
    "expo": "^54.0.34",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "^8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "geist": "^1.7.0",
    "hls.js": "^1.6.16",
    "posthog-js": "^1.383.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-track-player": "^4.1.2",
    "react-native-web": "^0.21.0",
    "serve": "^14.2.0",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/dompurify": "^3.2.0",
    "@types/react": "~19.1.17",
    "jsdom": "^25.0.1",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
